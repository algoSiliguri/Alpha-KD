# Alpha-KD environment variables — copy to .env and fill in values
# Never commit .env to source control

# Data and model paths
DATA_DIR=
MODELS_DIR=

# Broker selection: mt5 or upstox
BROKER_TYPE=

# Trading defaults
DEFAULT_SYMBOL=
DEFAULT_TIMEFRAME=

# MetaTrader5 credentials (if BROKER_TYPE=mt5)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Upstox credentials (if BROKER_TYPE=upstox)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=
